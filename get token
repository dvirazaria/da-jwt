  try {
    const jwtToken = jwt.sign(payload, privateKey, { algorithm: 'RS256' });

    const response = await axios.post(tokenUri, new URLSearchParams({
      grant_type: "urn:ietf:params:oauth:grant-type:jwt-bearer",
